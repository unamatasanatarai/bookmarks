#!/usr/bin/env bash

cd "${0%/*}" || exit 1

[[ $# -eq 0 ]] && {
  echo "usage: ${0##*/} url"
  exit 1
}

url="${1%/}"
readme="README.md"

# Avoid duplicates
if grep -Fq "($url)" "$readme" 2>/dev/null; then
  echo "[!] URL already exists"
  exit 0
fi

echo "Fetching page..."

# Try to get title, fallback to URL
html=$(curl -fsL --max-time 10 "$url")

if [[ $html =~ \<title\>([^<]+) ]]; then
  title="${BASH_REMATCH[1]}"
fi

if [[ -n "$title" ]]; then
  desc="$title"
  commit_msg="$title"
else
  desc="$url"
  commit_msg="Added $url"
fi

# Append to README
echo "- [$desc]($url)" >> "$readme"
echo "[+] Added: [$desc]($url)"

# Git commit & push
read -r -p "commit? [N/y] " ans
if [[ "${ans:0:1}" =~ [Yy] ]]; then
  git add "$readme"
  git commit -m "$commit_msg" || { echo "Nothing to commit"; exit 0; }
  git push origin main
fi